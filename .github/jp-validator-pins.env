# JP FHIR Validator Bridge — pin file (P2-13 PR3 sub-PR-C 高度化, session 48)
#
# validator_cli.jar / JP IG packages のバージョンと SHA256 を集約。
# `.github/workflows/jp-validate.yml` と `scripts/validate_jp.sh` が
# source して version-immutable な pinning を行う。
#
# **STRICT モード**(推奨、CI default):
#   すべての SHA256 が空でない → 実測 SHA256 と一致しないと fail。
#
# **BOOTSTRAP モード**(初期化 or version 昇格時のみ):
#   SHA256 空欄で validate_jp.sh を回し、`scripts/pin_jp_validator.sh` で
#   実測 SHA256 を printf → この env に書き戻し + commit。
#
# 更新手順:
#   1. VALIDATOR_VERSION を最新 stable release tag に上げる
#      (https://github.com/hapifhir/org.hl7.fhir.core/releases)
#   2. 該当 SHA256 を空欄化
#   3. `bash scripts/pin_jp_validator.sh` を実行
#   4. 出力される新 SHA256 を該当行に貼り付け + commit
#
# 参照:docs/jp-clins.md「JP FHIR Validator Bridge」節

# ─────────────────────────────────────────────────────────────
# HL7 官方 FHIR Validator CLI(hapifhir/org.hl7.fhir.core release)
# ─────────────────────────────────────────────────────────────
#
# Release URL パターン:
#   https://github.com/hapifhir/org.hl7.fhir.core/releases/download/<VERSION>/validator_cli.jar
#
# 空欄時:workflow は soft-mode で警告 + validation を実行(bootstrap 用)。
# 値ありのとき:workflow は strict-mode で sha256 mismatch → fail。
VALIDATOR_VERSION=6.4.3
VALIDATOR_SHA256=

# ─────────────────────────────────────────────────────────────
# JP IG packages(version pin)
# ─────────────────────────────────────────────────────────────
#
# validator は `-ig <id>#<version>` 形式で packages.fhir.org / packages.simplifier.net
# から package.tgz を取得する(NPM-style FHIR package registry)。
# JP Core は packages.fhir.org に安定版がある(id=jp-core.r4)。
# JP-CLINS / JP-eCheckup は 2026-07 時点で package registry 到達性が
# 不確実なため、直接 tarball URL(jpfhir.jp)も allow する。
#
# 使い方:
#   *_PACKAGE_ID + *_PACKAGE_VERSION 両方指定 → -ig <id>#<version>
#   *_PACKAGE_URL 指定 → -ig <ローカルにダウンロードした .tgz path>
#   両方空 → validator の profile URL online 解決に fallback(v0.2 挙動)

JP_CORE_PACKAGE_ID=jp-core.r4
JP_CORE_PACKAGE_VERSION=1.1.7
JP_CORE_PACKAGE_URL=
JP_CORE_PACKAGE_SHA256=

JP_CLINS_PACKAGE_ID=
JP_CLINS_PACKAGE_VERSION=
# 例:https://jpfhir.jp/fhir/eDischargeSummary/1.12.0/package.tgz
JP_CLINS_PACKAGE_URL=
JP_CLINS_PACKAGE_SHA256=

JP_ECHECKUP_PACKAGE_ID=
JP_ECHECKUP_PACKAGE_VERSION=
JP_ECHECKUP_PACKAGE_URL=
JP_ECHECKUP_PACKAGE_SHA256=
